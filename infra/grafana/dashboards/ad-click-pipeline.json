      "type": "stat",
      "title": "Watcher — click RPS (accepted)",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(watcher_clicks_accepted_total[1m]))",
          "legendFormat": "accepted/s"
        }
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "graphMode": "area"}
    },
    {
      "type": "timeseries",
      "title": "Watcher HTTP — RPS per instance",
      "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (instance) (rate(http_server_requests_seconds_count{service=\"click-event-watcher\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Watcher HTTP — p95 latency",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{service=\"click-event-watcher\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
